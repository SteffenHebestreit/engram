# --- Storage backend ---
# "neo4j"    (default) graph + vector in one store, with GDS personalized-
#            PageRank graph proximity
# "pgvector" PostgreSQL + pgvector — a lighter graph-lite alternative: vector +
#            fulltext + sequence/keyword siblings still work, but graph
#            proximity degrades to per-hop decay (no GDS PageRank), and the
#            structured-entity endpoints (/graph/entities|relations) are
#            neo4j-only
# "engramdb" the embedded backend — runs IN-PROCESS (no server to deploy),
#            fastest backend at every scale, with optional b1 quantization for
#            ~32x less vector memory, at parity retrieval quality. Decay
#            proximity (no PPR), no community/structured-entity graph. The
#            zero-infra on-ramp; see docs/engram-db.md.
STORE_BACKEND=neo4j

# --- Engram-DB embedded backend (only when STORE_BACKEND=engramdb) ---
# optional pickle-snapshot path for persistence; empty = in-memory only
ENGRAMDB_PATH=
# vector quantization: "f16" (½ memory, lossless ranking — default), "f32"
# (exact), "i8" (¼ memory), "b1" (1/32 memory — 2-stage hamming-shortlist +
# exact-cosine rescore, matches f32 ranking on the real stack)
ENGRAMDB_QUANTIZATION=f16

# --- Logging ---
# root log level; DEBUG adds a per-search diagnostics line (timing, candidate
# counts, which degradation fallbacks fired)
LOG_LEVEL=INFO

# --- Community synthesis (GraphRAG-style theme layer; neo4j+GDS only) ---
# smallest Leiden community kept when building the community layer via
# POST /communities/rebuild or scripts.build_communities
COMMUNITY_MIN_SIZE=1

# --- Graph database (neo4j backend) ---
# NEO4J_URI is set by docker compose (bolt://neo4j:7687 inside the network);
# only user/password are configurable here
NEO4J_USER=neo4j
NEO4J_PASSWORD=engram

# --- PostgreSQL (pgvector backend) ---
# docker compose sets POSTGRES_DSN to the in-network postgres service for the
# api/tests containers; only needed when STORE_BACKEND=pgvector
# POSTGRES_DSN=postgresql://engram:engram@postgres:5432/engram

# --- Embedding endpoint (OpenAI-compatible, e.g. TEI / Infinity / vLLM / Ollama on your network) ---
# note: the service runs inside Docker; an endpoint running on *this*
# machine is reachable as http://host.docker.internal:<port>, not localhost
EMBEDDING_API_BASE=http://your-embedding-host:8080/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# Asymmetric retrieval instructions for instruction-tuned embedders (E5 / GTE /
# Qwen3-Embedding / NV-Embed / bge-*-v1.5). These models prepend a task
# instruction to the query (and sometimes the passage) and lose recall without
# it. BGE-M3 (the default) needs NONE, so both default to empty = current
# behavior. Applied to the dense channels only (BM25/fulltext keeps raw text).
# PASSAGE side changes stored vectors (part of the schema signature; set before
# first ingest). Examples:
#   E5:               QUERY_INSTRUCTION="query: "   PASSAGE_INSTRUCTION="passage: "
#   bge-v1.5 (en):    QUERY_INSTRUCTION="Represent this sentence for searching relevant passages: "
QUERY_INSTRUCTION=
PASSAGE_INSTRUCTION=

# --- LLM endpoint (OpenAI-compatible chat API) ---
# The default ingest path (METADATA_EXTRACTOR=yake) makes NO LLM calls. This
# endpoint is used by: query-time HyDE (on by default, silently skipped if the
# endpoint is down), and the opt-in METADATA_EXTRACTOR=default /
# CONTEXTUAL_RETRIEVAL_ENABLED / community reports. Leave unset to run fully
# LLM-free (HyDE then degrades to the plain query).
LLM_API_BASE=http://your-llm-host:8000/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5-14b-instruct
# set to false if the server does not support response_format={"type":"json_object"}
LLM_JSON_MODE=true

# Optional SEPARATE small/fast endpoint for the per-chunk metadata extractor
# (METADATA_EXTRACTOR=default) ONLY — the high-volume, low-difficulty LLM call
# (3-8 keywords + a one-sentence summary as JSON). Point it at a small model so
# the stronger LLM_MODEL above still handles HyDE / contextual / community. Each
# field falls back to its LLM_* counterpart when blank, so leaving these unset
# changes nothing. Recommended: Qwen3-1.7B-Instruct-2507 (Qwen3-0.6B if VRAM/
# latency-bound). On Qwen3 use the *-Instruct-2507 weights (non-thinking by
# design) or disable thinking (/no_think) — otherwise it wastes tokens reasoning.
# Serve with constrained JSON (vLLM guided_json / llama.cpp GBNF) for the small
# model. Compare candidates with `python -m bench.extractor_bench`.
EXTRACTION_LLM_API_BASE=
EXTRACTION_LLM_API_KEY=
EXTRACTION_LLM_MODEL=
# cap on extraction output tokens (the reply is only a few dozen): bounds tail
# latency and stops a tiny model that fails to stop from burning REQUEST_TIMEOUT.
# 0 = no cap (current behavior); 96 is a good value when using a small model.
EXTRACTION_MAX_TOKENS=0
# chunks shorter than this skip the LLM call and fall back to statistical
# keywords + first sentence (titles/headers/list items). 0 = every chunk hits
# the LLM (current behavior).
EXTRACTION_MIN_CHARS=0
# response_format for the extraction call (general across serving stacks):
#   ""           inherit LLM_JSON_MODE (json_object when true) — the default,
#                accepted by vLLM / Ollama / llama.cpp / OpenAI.
#   json_schema  send the {keywords,summary} schema => GUARANTEED valid JSON, and
#                it suppresses chain-of-thought on servers that gate reasoning
#                behind free-form output. REQUIRED for LM Studio (it rejects
#                json_object). The portable way to make a tiny model reliable.
#   text/none    no response_format (rely on engram's tolerant parser).
EXTRACTION_RESPONSE_FORMAT=
# Serving-specific reasoning controls merged at the TOP LEVEL of the extraction
# request body, as JSON. STACK-DEPENDENT — set what YOUR server needs (this is the
# general escape hatch, not LM-Studio-specific):
#   vLLM Qwen3:        {"chat_template_kwargs": {"enable_thinking": false}}
#   Ollama / LM Studio: {"reasoning_effort": "none"}
# Often unnecessary if EXTRACTION_RESPONSE_FORMAT=json_schema already stops the
# reasoning (verify with bench/extractor_bench.py's `tok`/`rsn` columns). {} = none.
# Thinking models (Qwen3, Gemma 4, ...) waste tokens reasoning on this trivial task,
# so disable it for whichever model/stack you run.
EXTRACTION_EXTRA_BODY={}

# --- Reranker endpoint ---
# format: "tei"  -> POST {base}/rerank {"query","texts"}            (text-embeddings-inference)
#         "jina" -> POST {base}/rerank {"model","query","documents"} (Jina / Infinity / Cohere-style)
RERANKER_API_BASE=http://your-reranker-host:8081
RERANKER_API_KEY=
# bge-reranker-v2-m3 is the safe default. For a measured +3.15/+3.84 nDCG@10
# upgrade (SciFact/NFCorpus, drop-in, multilingual) use Qwen3-Reranker via the
# sidecar in deploy/reranker (TEI can't serve its causal-LM format):
#   RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B  RERANKER_API_BASE=http://reranker:8091
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_FORMAT=tei
# disable to skip the cross-encoder entirely (results fall back to the fused
# score, like a reranker-down); reranker_strategy selects a registered reranker
RERANKER_ENABLED=true
# "http" = the cross-encoder above; "colbert" = cheap BGE-M3 late-interaction
# (MaxSim) reranker via COLBERT_API_BASE below — ~100x cheaper, not a quality
# upgrade over the cross-encoder (see deploy/bge-m3 and app/rerank.py)
RERANKER_STRATEGY=http

# --- Learned-sparse channel (opt-in; BGE-M3 lexical_weights) ---
# Folds an exact-term (SPLADE-style) score into the fused score, before the
# shortlist + reranker — the precision the dense vector smooths away (rare
# entities, IDs, numbers). engram already runs BGE-M3, so this is "free": point
# SPARSE_API_BASE at a multi-output endpoint (see deploy/bge-m3, which serves
# dense + sparse + ColBERT from one model). Degrades to a no-op when down.
# Endpoint contract: POST {SPARSE_API_BASE}/embed_sparse {"input":[texts]}
#   -> {"data":[{"index":i,"lexical_weights":{token:weight}}]}
SPARSE_ENABLED=false
SPARSE_API_BASE=
SPARSE_API_KEY=
SPARSE_MODEL=BAAI/bge-m3
# share of the sparse signal in the fused score (alongside retrieval/median/graph)
SPARSE_WEIGHT=0.2

# --- Memory write-path: near-duplicate handling (M1; opt-in) ---
# When on, ingest links a fresh chunk that is >= DEDUP_COSINE_THRESHOLD cosine-
# similar to an existing chunk in another document (the canonical), and search
# collapses near-duplicate clusters to their best-retrieved member — so an agent
# re-ingesting the same knowledge (paraphrased, across sources/sessions) can't
# flood the candidate pool. Non-destructive: the duplicate is still stored and
# linked (near_dup_of), never dropped. The threshold is EMBEDDER-COUPLED — tune
# it on your own BGE-M3 vectors (boilerplate / near-identical numbers sit high).
DEDUP_ENABLED=false
DEDUP_COSINE_THRESHOLD=0.95
DEDUP_CANDIDATE_K=5

# --- Recency / temporal decay (opt-in; post-rerank, the agent-memory signal) ---
# Blend an exponential recency factor on each candidate's document age into the
# final ordering, so among similarly-relevant results newer ones rank higher.
RECENCY_ENABLED=false
RECENCY_WEIGHT=0.2
RECENCY_HALF_LIFE_DAYS=30

# --- Agent-memory write-path boost (opt-in; the learning side of /feedback) ---
# When an agent marks chunks as *used* for a query (POST /feedback, MCP mark_used),
# engram stores the (query-embedding -> used-chunk) association; a later SIMILAR
# query then injects those chunks into the rerank shortlist. Retrieval improves
# from real usage over time — an operational/agent-memory capability a stateless
# retriever can't provide. NOTE: this is operational value (cross-session memory,
# personalization, recurring queries); it shows no benchmark quality lift with a
# strong embedder (base retrieval already finds the gold). engramdb backend only.
MEMORY_BOOST_ENABLED=false
MEMORY_BOOST_WEIGHT=0.5
MEMORY_BOOST_MIN_SIM=0.6
MEMORY_BOOST_MAX_NEIGHBORS=20

# --- Contextual Retrieval (Anthropic; opt-in) ---
# At ingest, an LLM writes a short document-situating context per chunk, prepended
# before embedding so the vector encodes document-level identity. Changes stored
# vectors (part of the schema signature; set before first ingest). Needs LLM_API_BASE.
CONTEXTUAL_RETRIEVAL_ENABLED=false

# --- ColBERT reranker endpoint (only used when RERANKER_STRATEGY=colbert) ---
# Contract: POST {COLBERT_API_BASE}/rerank_colbert {"query","texts":[...]}
#   -> {"data":[{"index":i,"score":float}]}
COLBERT_API_BASE=
COLBERT_API_KEY=
COLBERT_MODEL=BAAI/bge-m3

# --- HTTP client (embedding/LLM/reranker calls) ---
# per-request timeout (seconds), a shorter one for optional HyDE generation,
# and the shared client's connection-pool ceiling
REQUEST_TIMEOUT=120
HYDE_TIMEOUT=30
HTTP_MAX_CONNECTIONS=64

# --- Chunking ---
# registered chunker strategy (built-in: "fixed"); see app/chunking.py
CHUNK_STRATEGY=fixed
CHUNK_TARGET_CHARS=1800
# overlap defaults to 0: engram pulls a hit's neighbouring chunks via the
# NEXT_CHUNK graph, so the seam context an overlap would duplicate is already
# recovered (naive RAG needs overlap because it has no such graph). Raise it only
# if you run without graph expansion.
CHUNK_OVERLAP_CHARS=0

# --- Metadata extraction ---
# registered extractor strategy (see app/llm.py):
#   "yake"    (default) statistical keywords + the chunk's lead sentence as the
#             summary. NO LLM call at ingest — ingestion needs no chat endpoint
#             and isn't bottlenecked on per-chunk generation — yet still builds
#             the cross-document keyword graph (HAS_KEYWORD + sibling expansion).
#   "default" opt-in quality upgrade: an LLM writes a sharper one-sentence
#             summary + keywords per chunk (one /chat/completions call per fresh
#             chunk; needs LLM_API_BASE). Slower ingest; measure before relying
#             on it — there is no benchmark showing it beats "yake" on retrieval.
#   "none"    no metadata at all (cheapest; pair with content-only channels).
METADATA_EXTRACTOR=yake

# --- Ingestion throughput ---
# max parallel LLM calls in flight during ingest — applies only to the LLM
# paths (METADATA_EXTRACTOR=default and/or CONTEXTUAL_RETRIEVAL_ENABLED); the
# default no-LLM "yake" path ignores it. Raise it (8-16) if your chat server
# batches (vLLM/TGI); no effect on a single-instance llama.cpp.
EXTRACTION_CONCURRENCY=4
# embeddings are requested in batches of this size (most servers cap the
# per-request batch size, e.g. TEI defaults to 32) ...
EMBEDDING_BATCH_SIZE=64
# ... with at most this many embedding requests in flight at once
EMBEDDING_CONCURRENCY=4
# incremental re-ingest: when replacing a document, reuse the stored vectors +
# metadata of chunks whose text is unchanged, so only changed chunks pay for
# fresh LLM extraction + embedding
REUSE_UNCHANGED_CHUNKS=true

# --- Search tuning ---
TOP_K_PER_INDEX=12
SEED_COUNT=8
KEYWORD_SIBLING_LIMIT=5
# total-score recipe: retrieval + median-proximity + graph-proximity
RETRIEVAL_WEIGHT=0.55
MEDIAN_WEIGHT=0.30
GRAPH_PROXIMITY_WEIGHT=0.15
FULLTEXT_CHANNEL_WEIGHT=0.7
RERANK_TOP_K=15
FINAL_TOP_K=8

# --- Graph expansion ---
# how many NEXT_CHUNK hops before/after a seed to consider
SEQUENCE_MAX_HOPS=3
# "decay" = fixed per-hop fade (default; benchmarks showed PPR adds no quality
# over decay yet is the costliest store op — see docs/engram-db.md), "ppr" =
# personalized PageRank via the GDS plugin (auto-falls back to decay)
GRAPH_PROXIMITY_MODE=decay
PPR_DAMPING=0.85
SEQUENCE_PROXIMITY_DECAY=0.7

# --- Search preset (see app/presets.py) ---
# default named bundle applied when a /search request names none: "" (no preset),
# "cheap" (no HyDE/reranker, decay proximity), "balanced", or "max_quality".
# A per-request tuning {"preset": "..."} and explicit tuning fields override it.
SEARCH_PRESET=

# --- Pipeline strategies (see app/pipeline.py) ---
# swappable stage algorithms; defaults reproduce the original pipeline
FUSION_STRATEGY=dbsf_convex
EXPANDER_STRATEGY=sequence_keyword
# adaptive query routing (app/routing.py): auto-select a preset per query so
# callers (e.g. an agent) don't tune every request and simple queries stay cheap.
# "" = off (use SEARCH_PRESET); "heuristic" = the no-LLM built-in classifier
# (factoid->balanced, complex/thematic->max_quality). An explicit per-request
# preset/tuning always overrides the router.
ROUTER_STRATEGY=

# --- Extensibility (advanced) ---
# Full override of the vector channel set as JSON (default: the built-in three
# weighted from the *_CHANNEL_WEIGHT settings above). Each channel needs a
# unique index + embedding_prop; the content channel must keep content_embedding
# (the geometry vector used for median-proximity / MMR).
# VECTOR_CHANNELS=[{"name":"content","index":"chunk_content_idx","embedding_prop":"content_embedding","source":"text","weight":1.0},{"name":"summary","index":"chunk_summary_idx","embedding_prop":"summary_embedding","source":"summary","weight":0.9}]
#
# Graph schema profile driving the GDS projection as JSON (default: the document
# profile, Chunk/Keyword over NEXT_CHUNK/HAS_KEYWORD). Extend it to project
# domain entity nodes/relations loaded via POST /graph/entities + /graph/relations.
# GRAPH_PROFILE={"name":"mfa","projection_labels":["Chunk","EbmCode"],"projection_relationships":[{"type":"NEXT_CHUNK"},{"type":"HAS_KEYWORD"},{"type":"ABOUT"},{"type":"EXCLUDES_SAME_QUARTAL","sign":-1}]}
#
# Startup guard when the embedding model/dim or channel set no longer match the
# indexes already in the store: "error" = refuse to start, "warn" = log + adopt,
# "off" = silently adopt
SCHEMA_GUARD_MODE=error

# --- Shortlist & result shaping ---
# MMR: relevance (lambda) vs. diversity (1 - lambda) when picking the
# rerank shortlist; 1.0 = pure top-k
MMR_LAMBDA=0.7
# autocut: stop returning results after the first rerank-score cliff
AUTOCUT_ENABLED=true
AUTOCUT_MIN_KEEP=3
AUTOCUT_MIN_GAP=0.25

# --- HyDE (hypothetical document embeddings) ---
# short queries are embedded as a blend with an LLM-written hypothetical
# answer; falls back to the plain query if the LLM is unreachable
HYDE_ENABLED=true
HYDE_MAX_QUERY_WORDS=8
HYDE_QUERY_WEIGHT=0.5

# --- Content-only ingest profile (opt-in) ---
# The default (METADATA_EXTRACTOR=yake) is already LLM-free at ingest. To go all
# the way to the naive baseline — ONE embedding per chunk, no keyword graph —
# drop the summary/keywords channels too. Trade-off vs the yake default: loses
# keyword-sibling graph expansion and the summary's fulltext contribution. Apply
# on a fresh store (it changes the schema signature).
# METADATA_EXTRACTOR=none
# SUMMARY_CHANNEL_ENABLED=false
# KEYWORDS_CHANNEL_ENABLED=false
# HYDE_ENABLED=false
